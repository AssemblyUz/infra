{$APP_DOMAIN} {
	encode zstd gzip

	@backend path /api/* /healthz /healthz/ /i18n/* {$ADMIN_PREFIX:/admin} {$ADMIN_PREFIX:/admin}/ {$ADMIN_PREFIX:/admin}/* /static/*
	handle @backend {
		reverse_proxy api:8000
	}

	handle_path /media/* {
		root * /srv/media
		file_server
	}

	handle {
		reverse_proxy frontend:3000
	}
}

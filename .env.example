# Copy to /opt/assembly/.env on the server and fill in real values.

APP_DOMAIN=example.com
APP_ENV_FILE=/opt/assembly/.env

BACKEND_IMAGE=ghcr.io/assemblyuz/backend:latest
FRONTEND_IMAGE=ghcr.io/assemblyuz/frontend:latest

SECRET_KEY=replace-me-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=example.com
ADMIN_URL=admin/
ADMIN_PATH=/admin/*

CORS_ALLOWED_ORIGINS=https://example.com
CSRF_TRUSTED_ORIGINS=https://example.com

POSTGRES_DB=assembly
POSTGRES_USER=assembly
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgres://assembly:replace-me@db:5432/assembly

API_URL=http://api:8000
WEB_CONCURRENCY=1
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30

TIME_ZONE=Asia/Tashkent
LOG_LEVEL=INFO

CONTACT_THROTTLE_RATE=5/hour
CONTACT_NOTIFY_EMAILS=info@example.com

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

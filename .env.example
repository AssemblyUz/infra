# Production defaults. The deploy script copies this to /opt/assembly/infra/.env
# on first deploy and replaces placeholder secrets with generated values.

APP_DOMAIN=assembly.uz
APP_ENV_FILE=/opt/assembly/infra/.env
APP_DATA_DIR=/opt/assembly/data

BACKEND_IMAGE=ghcr.io/assemblyuz/backend:latest
FRONTEND_IMAGE=ghcr.io/assemblyuz/frontend:latest

SECRET_KEY=replace-me-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=assembly.uz,api,79.76.124.32,localhost,127.0.0.1
ADMIN_URL=admin/
ADMIN_PREFIX=/admin
ADMIN_PATH=/admin/*

CORS_ALLOWED_ORIGINS=https://assembly.uz
CSRF_TRUSTED_ORIGINS=https://assembly.uz
SECURE_SSL_REDIRECT=False

POSTGRES_DB=assembly
POSTGRES_USER=assembly
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgres://assembly:replace-me@db:5432/assembly

API_URL=http://api:8000
WEB_CONCURRENCY=1
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30

TIME_ZONE=Asia/Tashkent
LOG_LEVEL=INFO

CONTACT_THROTTLE_RATE=5/hour
CONTACT_NOTIFY_EMAILS=info@assembly.uz

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@assembly.uz
